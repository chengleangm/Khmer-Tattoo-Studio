{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "khmer-tattoo-studio",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-07-13",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "khmer-tattoo-studio"
		}
	],
	"r2_buckets": [
		{
			"binding": "STUDIO_STORAGE",
			"bucket_name": "khmer-tattoo-studio"
		}
	]
}
